# Copy to .kamal/secrets and fill in real values.
# NEVER commit .kamal/secrets — it contains credentials.

# OCIR credentials via OCI Instance Principal — no static auth token needed.
# The IMDS token is fetched from the OCI instance over SSH each time kamal runs.
OCIR_USERNAME=ax53jfkrslfs/id_token
OCIR_AUTH_TOKEN=$(ssh deploy@138.2.41.115 'curl -sf -H "Authorization: Bearer Oracle" http://169.254.169.254/opc/v2/identity/token')

# Cloudflare Tunnel token
# Create at: https://one.dash.cloudflare.com → Networks → Tunnels → Create a tunnel
# Copy the token shown in the "Install connector" step.
TUNNEL_TOKEN=<cloudflare-tunnel-token>

# PostgreSQL credentials (used by both Elixir env and postgres accessory)
DB_USER=sukhi
DB_PASS=<strong-random-password>
POSTGRES_USER=sukhi
POSTGRES_PASSWORD=<same-strong-random-password>

# Grafana admin password
GF_SECURITY_ADMIN_PASSWORD=<strong-random-password>
