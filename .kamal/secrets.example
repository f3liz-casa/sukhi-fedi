# SPDX-License-Identifier: AGPL-3.0-or-later
#
# Template. Copy to `.kamal/secrets` (gitignored) and fill in real
# values, OR keep this shell-expansion form and `export` the vars
# in the shell where you call `kamal`.
#
# Generate fresh values:
#   POSTGRES_PASSWORD=$(openssl rand -hex 24)
#   ERLANG_COOKIE=$(openssl rand -hex 32)
#   SECRET_KEY_BASE=$(openssl rand -hex 64)
#   RUSTFS_ACCESS_KEY=$(openssl rand -hex 12)
#   RUSTFS_SECRET_KEY=$(openssl rand -hex 32)
#
# REGISTRY_PASSWORD = 箱の private registry (127.0.0.1:5000) の basic-auth pass。
# htpasswd の user=sukhi 用。箱で先に sukhi を足す(techo とは別エントリ):
#   docker run --rm httpd:2-alpine htpasswd -Bbn sukhi '<pass>' >> ~/registry-auth/htpasswd
#   docker restart $(docker ps -qf ancestor=registry:2)   # htpasswd 反映
#
# S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY (used by gateway) must be the
# same values as RUSTFS_ACCESS_KEY / RUSTFS_SECRET_KEY (used by rustfs
# accessory). Easiest: define the rustfs pair, then alias the S3 pair.

REGISTRY_PASSWORD=$REGISTRY_PASSWORD
POSTGRES_PASSWORD=$POSTGRES_PASSWORD
DB_PASS=$DB_PASS
ERLANG_COOKIE=$ERLANG_COOKIE
SECRET_KEY_BASE=$SECRET_KEY_BASE
RUSTFS_ACCESS_KEY=$RUSTFS_ACCESS_KEY
RUSTFS_SECRET_KEY=$RUSTFS_SECRET_KEY
S3_ACCESS_KEY_ID=$RUSTFS_ACCESS_KEY
S3_SECRET_ACCESS_KEY=$RUSTFS_SECRET_KEY

# OCI Email Delivery の SMTP 認証情報。OCI コンソール → Identity →
# (送信用の IAM ユーザー) → 「SMTP 認証情報」→ 生成、で出る 2 つ。
# パスワードは生成時に一度しか表示されない。username は長い OCID 形式。
# deploy.yml の gateway env.secret が参照するので、書かないうちは
# `kamal accessory reboot gateway` が secret 解決で止まる。
SMTP_USERNAME=$SMTP_USERNAME
SMTP_PASSWORD=$SMTP_PASSWORD

# Cloudflare Origin CA 証明書（*.f3liz.casa, Full (Strict) 用）。CF dashboard →
# SSL/TLS → Origin Server → Create Certificate で発行して PEM を保存:
#   config/tls/origin.crt  (Origin Certificate)
#   config/tls/origin.key  (Private Key — 発行時に一度だけ表示)
# techo と同じ 1 枚を共有してよい。
TLS_CERT=$(cat config/tls/origin.crt)
TLS_KEY=$(cat config/tls/origin.key)
