#
# Kamal reads this file at deploy time. Values are pulled from the
# environment of the shell running `kamal deploy`, NOT from this
# file directly — so this file is safe to commit.
#
# Set these before deploying. Recommended: direnv `.envrc` (gitignored)
# or 1Password CLI / pass / age-encrypted file.
#
# Required exports in the deploying shell:
#
#   export KAMAL_REGISTRY_PASSWORD='<GitHub PAT with read:packages>'
#   export POSTGRES_PASSWORD='<openssl rand -hex 24>'
#   export DB_PASS="$POSTGRES_PASSWORD"   # must match postgres password
#   export ERLANG_COOKIE='<openssl rand -hex 32>'   # distributed-Erlang shared secret
#
# Rotation: if you change ERLANG_COOKIE, gateway and api must redeploy
# together — they can't talk while their cookies differ.

KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
POSTGRES_PASSWORD=$POSTGRES_PASSWORD
DB_PASS=$DB_PASS
ERLANG_COOKIE=$ERLANG_COOKIE
