# Copy this file to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars — it contains secrets.

tenancy_ocid        = "ocid1.tenancy.oc1..aaaa..."
user_ocid           = "ocid1.user.oc1..aaaa..."
fingerprint         = "aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99"
private_key_path    = "/home/you/.oci/oci_api_key.pem"
region              = "ap-mumbai-1"
compartment_ocid    = "ocid1.compartment.oc1..aaaa..."
tenancy_namespace   = "axyz1234abc"
domain              = "fedi.example.com"

# Pick any AD where VM.Standard.E2.1.Micro is available. Not every AD has
# x64 capacity — if apply fails with "Out of host capacity", try a different
# AD in the same region.
availability_domain = "kWfj:AP-MUMBAI-1-AD-1"
ssh_public_key_path = "/home/you/.ssh/id_ed25519.pub"

# Free-tier defaults — change only if you have quota headroom
# boot_volume_size_gb  = 50
# block_volume_size_gb = 50
