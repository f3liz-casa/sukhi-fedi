# SPDX-License-Identifier: AGPL-3.0-or-later
#
# Template for /etc/sukhi-fedi/backup.env  (chmod 600, owned by root).
# Read by sukhi-backup.sh / sukhi-backup-verify.sh via their systemd units.
#
# These are SEPARATE from .kamal/secrets — the backup runs on the host via
# systemd timers, not through Kamal. Copy this file, fill it in, and place it
# at /etc/sukhi-fedi/backup.env. See README.md for the full activation steps.

# ── restic repository on Backblaze B2 (S3-compatible) ────────────────────────
# Create a private B2 bucket, then an application key scoped to it. Harden the
# key with "no delete" so a compromised host can't run `restic forget --prune`
# and erase your history; enable bucket Object Lock / versioning too.
RESTIC_REPOSITORY=s3:s3.us-west-004.backblazeb2.com/CHANGE-ME-sukhi-backup
AWS_ACCESS_KEY_ID=CHANGE-ME-b2-key-id
AWS_SECRET_ACCESS_KEY=CHANGE-ME-b2-application-key

# Encryption passphrase for the restic repo. Generate once and store it
# somewhere reachable WITHOUT this host — a lost repo password means an
# unrecoverable backup:
#   openssl rand -hex 32
RESTIC_PASSWORD=CHANGE-ME-restic-passphrase

# ── Postgres ─────────────────────────────────────────────────────────────────
# Same password as POSTGRES_PASSWORD / DB_PASS in .kamal/secrets.
PGPASSWORD=CHANGE-ME-postgres-password
PG_CONTAINER=sukhi-fedi-postgres
PG_USER=sukhi
PG_DB=sukhi_fedi

# ── rustfs object store (media + inbound + outbound archive buckets) ─────────
# Host path of the rustfs Kamal bind-mount.
RUSTFS_DATA_DIR=/home/rocky/sukhi-fedi-rustfs/data

# ── Container logs ───────────────────────────────────────────────────────────
# Rotated json-file logs, included so logs survive host loss. Empty = skip.
DOCKER_CONTAINERS_DIR=/var/lib/docker/containers

# ── Dead-man's switch (alert when a backup silently stops) ───────────────────
# A URL pinged ONLY on success — Healthchecks.io / Uptime Kuma push. A missed
# ping is what alerts you. Use two distinct checks so "backups stopped" and
# "backups run but fail verification" are distinguishable. Empty = disabled.
HEALTHCHECK_URL=
VERIFY_HEALTHCHECK_URL=
