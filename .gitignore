# Terraform
infra/terraform/terraform.tfvars
infra/terraform/.terraform/
infra/terraform/*.tfstate
infra/terraform/*.tfstate.*
infra/terraform/*.tfplan
infra/terraform/.terraform.lock.hcl
infra/terraform-x64-freetier/terraform.tfvars
infra/terraform-x64-freetier/.terraform/
infra/terraform-x64-freetier/*.tfstate
infra/terraform-x64-freetier/*.tfstate.*
infra/terraform-x64-freetier/*.tfplan
infra/terraform-x64-freetier/.terraform.lock.hcl

# Local env files
.env
.env.x64-freetier
.env.kamal.local

# Kamal secrets — values are environment-specific and must never be
# committed. The repo ships only `.kamal/secrets.example` as a template.
.kamal/secrets

# TLS origin cert/key (Cloudflare Origin CA) — never commit private keys.
config/tls/

.claude/
# Julia analysis tooling — resolved on demand via Pkg.instantiate()
analysis/Manifest.toml
