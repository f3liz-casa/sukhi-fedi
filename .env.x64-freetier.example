# Copy to .env on the target VM before `docker compose up`.
# NEVER commit the real .env — ERLANG_COOKIE is a shared secret.

SUKHI_REPO_OWNER=nyanrus
SUKHI_VERSION=v1

# Public domain fronting this deployment (Cloudflare Tunnel target).
DOMAIN=nodeinfo-watch.example.tld

# openssl rand -hex 32
ERLANG_COOKIE=change-me-to-a-long-random-string

# server_version_watcher preset = nodeinfo_monitor + feeds + pinned_notes.
# See docs/ADDONS.md:149-159.
ADDON_PRESETS=server_version_watcher
DISABLE_ADDONS=
