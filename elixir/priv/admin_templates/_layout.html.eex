<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= h(page_title) %> · sukhi-fedi admin</title>
  <script src="https://unpkg.com/htmx.org@2.0.4" integrity="sha384-HGfztofotfshcF7+8n44JQL2oJmowVChPTg48S+jvZoztPfvwD79OC/LTtG6dMp+" crossorigin="anonymous"></script>
  <style>
    :root {
      --bg: #f7f7f5;
      --panel: #ffffff;
      --border: #e3e3df;
      --text: #1a1a1a;
      --muted: #6b6b66;
      --accent: #1f6feb;
      --danger: #c93636;
      --ok: #2c8a4e;
    }
    * { box-sizing: border-box; }
    body { margin: 0; font: 14px/1.5 -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif; color: var(--text); background: var(--bg); }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    header.topbar { background: #fff; border-bottom: 1px solid var(--border); padding: 0 24px; display: flex; align-items: center; gap: 32px; height: 56px; }
    header.topbar .brand { font-weight: 600; }
    header.topbar nav { display: flex; gap: 20px; flex: 1; }
    header.topbar nav a { color: var(--text); padding: 4px 2px; border-bottom: 2px solid transparent; }
    header.topbar nav a.active { border-color: var(--accent); color: var(--accent); }
    header.topbar form { margin: 0; }
    header.topbar form button { background: none; border: 0; color: var(--muted); cursor: pointer; font: inherit; }
    main { max-width: 1100px; margin: 0 auto; padding: 24px; }
    h1 { font-size: 20px; margin: 0 0 16px; }
    h2 { font-size: 16px; margin: 24px 0 12px; }
    .panel { background: var(--panel); border: 1px solid var(--border); border-radius: 6px; padding: 16px; }
    table { width: 100%; border-collapse: collapse; }
    th, td { text-align: left; padding: 10px 12px; border-bottom: 1px solid var(--border); }
    th { font-weight: 600; color: var(--muted); font-size: 12px; text-transform: uppercase; letter-spacing: 0.04em; }
    tr:last-child td { border-bottom: 0; }
    .muted { color: var(--muted); }
    .pill { display: inline-block; padding: 1px 8px; border-radius: 10px; font-size: 12px; background: #ececea; color: var(--text); }
    .pill.suspended { background: #fde2e2; color: var(--danger); }
    .pill.silenced { background: #fff4d6; color: #946100; }
    .pill.ok { background: #dff1e3; color: var(--ok); }
    button, .btn { font: inherit; padding: 5px 10px; border: 1px solid var(--border); border-radius: 4px; background: #fff; cursor: pointer; color: var(--text); }
    button:hover, .btn:hover { background: #f0f0ee; }
    button.danger { color: var(--danger); border-color: #f1c2c2; }
    button.danger:hover { background: #fde2e2; }
    input[type=text], input[type=password], select, textarea {
      font: inherit; padding: 6px 10px; border: 1px solid var(--border); border-radius: 4px; background: #fff;
    }
    .flash { padding: 10px 14px; border-radius: 4px; margin: 0 0 16px; }
    .flash.info { background: #dff1e3; color: var(--ok); }
    .flash.error { background: #fde2e2; color: var(--danger); }
    .toolbar { display: flex; gap: 8px; align-items: center; margin-bottom: 12px; }
    .toolbar form { display: flex; gap: 8px; flex: 1; }
    .pager { display: flex; gap: 8px; justify-content: flex-end; margin-top: 12px; }
    .grid-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 12px; }
    .card { background: var(--panel); border: 1px solid var(--border); border-radius: 6px; padding: 14px; }
    .card .n { font-size: 28px; font-weight: 600; }
    .card .label { color: var(--muted); font-size: 12px; text-transform: uppercase; letter-spacing: 0.04em; }
    .bar { height: 6px; background: #ececea; border-radius: 3px; overflow: hidden; margin-top: 8px; }
    .bar > i { display: block; height: 100%; background: var(--accent); }
    .bar > i.hot { background: var(--danger); }
  </style>
</head>
<body>
<%= if admin do %>
  <header class="topbar">
    <span class="brand">sukhi-fedi · admin</span>
    <nav>
      <a href="/admin"<%= if current_path == "/admin", do: " class=\"active\"" %>>Dashboard</a>
      <a href="/admin/users"<%= if String.starts_with?(current_path, "/admin/users"), do: " class=\"active\"" %>>Users</a>
      <a href="/admin/reports"<%= if String.starts_with?(current_path, "/admin/reports"), do: " class=\"active\"" %>>Reports</a>
      <a href="/admin/invite_codes"<%= if String.starts_with?(current_path, "/admin/invite_codes"), do: " class=\"active\"" %>>Invites</a>
      <a href="/admin/instance_blocks"<%= if String.starts_with?(current_path, "/admin/instance_blocks"), do: " class=\"active\"" %>>Federation</a>
      <a href="/admin/system"<%= if String.starts_with?(current_path, "/admin/system"), do: " class=\"active\"" %>>System</a>
    </nav>
    <span class="muted"><%= h(admin.username) %></span>
    <form method="post" action="/admin/logout"><button type="submit">Sign out</button></form>
  </header>
<% end %>
<main>
<%= if Map.get(flash, :message) do %>
  <div class="flash <%= flash.level %>"><%= h(flash.message) %></div>
<% end %>
<%= inner %>
</main>
</body>
</html>
