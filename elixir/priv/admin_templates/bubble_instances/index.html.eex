<h1>Bubble (ご近所)</h1>

<p class="muted" style="margin-top: 0;">
  Public posts from these trusted remote hosts surface in the bubble timeline.
  An empty list means an empty bubble — curated, never a firehose.
</p>

<div class="panel" style="margin-bottom: 16px;">
  <h2 style="margin-top: 0;">Add a host</h2>
  <form method="post" action="/admin/bubble_instances" style="display: flex; gap: 8px;">
    <input type="text" name="domain" required placeholder="e.g. misskey.io" autocapitalize="none" style="flex: 1;">
    <button type="submit">Add</button>
  </form>
</div>

<div class="panel" style="margin-bottom: 16px;">
  <h2 style="margin-top: 0;">Find a host you already federate with</h2>
  <form method="get" action="/admin/bubble_instances" style="display: flex; gap: 8px;">
    <input type="text" name="q" value="<%= h(q) %>" placeholder="search known hosts…" autocapitalize="none" style="flex: 1;">
    <button type="submit">Search</button>
  </form>

<%= if searched do %>
<%= if suggestions == [] do %>
  <p class="muted" style="margin-bottom: 0;">No known hosts match “<%= h(q) %>” (or they are already in the bubble).</p>
<% else %>
  <ul style="list-style: none; padding: 0; margin: 12px 0 0;">
<%= for domain <- suggestions do %>
    <li style="display: flex; align-items: center; gap: 8px; padding: 4px 0; border-top: 1px solid var(--border);">
      <span style="flex: 1;"><%= h(domain) %></span>
      <form method="post" action="/admin/bubble_instances" style="display: inline;">
        <input type="hidden" name="domain" value="<%= h(domain) %>">
        <button type="submit">Add</button>
      </form>
    </li>
<% end %>
  </ul>
<% end %>
<% end %>
</div>

<div class="panel" style="padding: 0;">
<table>
  <thead>
    <tr>
      <th>Domain</th>
      <th>Added</th>
      <th style="width: 1%;"></th>
    </tr>
  </thead>
  <tbody>
<%= if current == [] do %>
    <tr><td colspan="3" class="muted" style="text-align: center; padding: 24px;">No hosts in the bubble yet.</td></tr>
<% else %>
<%= for b <- current do %>
    <tr>
      <td><strong><%= h(b.domain) %></strong></td>
      <td class="muted"><%= h(NaiveDateTime.to_iso8601(b.inserted_at)) %></td>
      <td>
        <form method="post" action="/admin/bubble_instances/<%= URI.encode(b.domain) %>/remove" style="display: inline;">
          <button type="submit">Remove</button>
        </form>
      </td>
    </tr>
<% end %>
<% end %>
  </tbody>
</table>
</div>
