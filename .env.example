# Copy to `.env` (gitignored) on the host before `docker compose up`.
# Reference: docs/ENV.md
#
# Generate secrets first:
#   ERLANG_COOKIE   = openssl rand -hex 32
#   DB_PASS         = openssl rand -hex 24
# ──────────────────────────────────────────────────────────────────

# ── Identity ──────────────────────────────────────────────────────
# Public hostname. No scheme, no port. Stamped into every outbound
# ActivityPub ID and HTTP-Sig keyId — changing it after users exist
# strands their federation identity.
DOMAIN=sukhi.example.tld

# Display name shown in nodeinfo and /api/v1/instance.
INSTANCE_TITLE=sukhi-fedi

# ── Secrets ───────────────────────────────────────────────────────
# Distributed-Erlang shared secret. The default `sukhi_fedi_dev_cookie`
# is a published string — leaving it unset on a production box is RCE.
ERLANG_COOKIE=change-me-to-a-long-random-string

# Cookie-signing key for the /admin web UI session. Must be stable
# across deploys — rotating invalidates every logged-in admin
# session and forces re-login. Generate: openssl rand -hex 64
SECRET_KEY_BASE=change-me-to-a-128-char-hex-string

# Postgres credentials. Override the upstream `postgres/postgres`
# defaults on any host where other workloads share the Docker network.
POSTGRES_USER=sukhi
POSTGRES_PASSWORD=change-me-to-a-long-random-string
DB_USER=sukhi
DB_PASS=change-me-to-a-long-random-string  # must equal POSTGRES_PASSWORD

# ── Image source ──────────────────────────────────────────────────
SUKHI_REPO_OWNER=f3liz-casa
# `v0` follows latest patch release. Pin to `v0.1.x` for stability.
SUKHI_VERSION=v0

# ── Addons (optional) ─────────────────────────────────────────────
# See docs/ADDONS.md for the catalog.
ENABLED_ADDONS=all
# DISABLE_ADDONS=nodeinfo_monitor
# ADDON_PRESETS=server_version_watcher

# ── Watchtower (optional, base compose only) ──────────────────────
# WATCHTOWER_POLL_INTERVAL=3600
# WATCHTOWER_NOTIFICATION_URL=

# ── Cloudflare Tunnel (optional, base compose only) ───────────────
# Required only if using cloudflared as the ingress. Coolify / Kamal
# users with native TLS proxies leave this empty.
# CLOUDFLARE_TUNNEL_TOKEN=
